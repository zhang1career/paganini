{
    "name": "zhang1career/paganini",
    "description": "A collection of utility classes for PHP",
    "type": "library",
    "version": "0.4.1",
    "license": "MIT",
    "keywords": ["utils", "utilities", "helper"],
    "authors": [
        {
            "name": "zhang1career",
            "email": "rongjin.zh@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "ext-apcu": "ApcuMemoStore: cross-request memo in the same FPM worker",
        "ext-redis": "phpredis client for RedisStringClient adapters",
        "ext-hash": "Required for xxh3 (CacheKeyGenerator); bundled with PHP in typical builds"
    },
    "autoload": {
        "psr-4": {
            "Paganini\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

